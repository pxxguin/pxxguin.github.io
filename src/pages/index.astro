    <!-- Recent Engineering Logs Section -->
    <div class="max-w-[var(--page-width)] mx-auto px-4 pt-8 pb-4 mb-4">
        <div class="flex justify-between items-end mb-6 section-header opacity-0 translate-y-8 transition duration-700 ease-out">
            <div class="text-left">
                <h2 class="text-3xl font-bold text-black/75 dark:text-white/75 mb-2">📝 Recent Engineering Logs</h2>
                <p class="text-black/50 dark:text-white/50">Sharing my learning journey and technical insights.</p>
            </div>
            <a href="/archive/" class="text-[var(--primary)] hover:text-[var(--primary-hover)] font-medium transition flex items-center gap-1 mb-1">
                View All <Icon name="material-symbols:arrow-forward-rounded" class="text-xl" />
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
             {latestPosts.slice(0, 3).map((entry) => (
                <GridPostCard
                    entry={entry}
                    title={entry.data.title}
                    tags={entry.data.tags}
                    category={entry.data.category}
                    published={entry.data.published}
                    url={getPostUrl(entry)}
                    image={entry.data.image}
                    description={entry.data.description}
                    class="h-full recent-post-card opacity-0 translate-y-8 transition duration-700 ease-out"
                />
            ))}
        </div>
    </div>

    <!-- Series Section -->
    <div class="max-w-[var(--page-width)] mx-auto px-4 pt-4 pb-8 mb-4">
        <div class="flex justify-between items-end mb-6 section-header opacity-0 translate-y-8 transition duration-700 ease-out">
            <div class="text-left">
                <h2 class="text-3xl font-bold text-black/75 dark:text-white/75 mb-2">📚 Featured Series</h2>
                <p class="text-black/50 dark:text-white/50">Curated collections of related posts.</p>
            </div>
            <a href="/series/" class="text-[var(--primary)] hover:text-[var(--primary-hover)] font-medium transition flex items-center gap-1 mb-1">
                View All <Icon name="material-symbols:arrow-forward-rounded" class="text-xl" />
            </a>
        </div>

        <!-- Carousel wrapper -->
        <div class="relative section-header opacity-0 translate-y-8 transition duration-700 ease-out">
            <!-- Prev button -->
            <button id="series-prev" class="absolute left-[-20px] top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white dark:bg-[#2a2a2a] shadow-lg border border-black/10 dark:border-white/10 flex items-center justify-center text-black/60 dark:text-white/60 hover:text-[var(--primary)] hover:border-[var(--primary)] transition hidden" aria-label="Previous">
                <Icon name="material-symbols:chevron-left-rounded" class="text-2xl" />
            </button>

            <!-- Slides container -->
            <div id="series-carousel" class="overflow-hidden">
                <div id="series-track" class="flex gap-6 transition-transform duration-500 ease-in-out">
                    {allSeries.map(s => (
                        <a href={`/series/${s.id}/`}
                           class="series-slide group flex-shrink-0 flex flex-col relative transition-all duration-300 hover:scale-[1.02]"
                           style="width: calc(50% - 12px);"
                        >
                            <div class="card-base border border-black/5 dark:border-white/5 h-full relative overflow-hidden bg-[var(--card-bg)] flex flex-col">
                                {s.image && (
                                    <div class="w-full h-64 overflow-hidden relative">
                                        <div class="absolute inset-0 bg-black/10 dark:bg-black/20 z-10"></div>
                                        <img src={s.image} alt={s.title} class="w-full h-full object-cover transition transform duration-500 group-hover:scale-110" />
                                    </div>
                                )}
                                <div class="p-6 flex flex-col flex-grow">
                                    <div class="flex items-center justify-between mb-3">
                                        <div class="text-[var(--primary)] text-sm font-bold bg-[var(--primary)]/10 px-2 py-1 rounded-md">
                                            {s.status === 'completed' ? 'Completed' : 'Ongoing'}
                                        </div>
                                        <div class="text-black/50 dark:text-white/50 text-sm font-medium">
                                            {s.count} Posts
                                        </div>
                                    </div>
                                    <h3 class="text-xl font-bold text-black/90 dark:text-white/90 mb-2 group-hover:text-[var(--primary)] transition duration-300">
                                        {s.title}
                                    </h3>
                                    <p class="text-sm text-black/60 dark:text-white/60 mb-4 line-clamp-3 flex-grow">
                                        {s.description}
                                    </p>
                                    <div class="flex items-center text-sm font-bold text-[var(--primary)] mt-auto">
                                        <span class="border-b-2 border-transparent group-hover:border-[var(--primary)] transition duration-300">View Series</span>
                                        <Icon name="material-symbols:chevron-right-rounded" class="text-xl group-hover:translate-x-1 transition duration-300" />
                                    </div>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Next button -->
            <button id="series-next" class="absolute right-[-20px] top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white dark:bg-[#2a2a2a] shadow-lg border border-black/10 dark:border-white/10 flex items-center justify-center text-black/60 dark:text-white/60 hover:text-[var(--primary)] hover:border-[var(--primary)] transition hidden" aria-label="Next">
                <Icon name="material-symbols:chevron-right-rounded" class="text-2xl" />
            </button>

            <!-- Dots -->
            <div id="series-dots" class="flex justify-center gap-2 mt-4"></div>
        </div>

        <script is:inline>
            (function() {
                const track = document.getElementById('series-track');
                const originalSlides = track ? Array.from(track.querySelectorAll('.series-slide')) : [];
                const prevBtn = document.getElementById('series-prev');
                const nextBtn = document.getElementById('series-next');
                const dotsContainer = document.getElementById('series-dots');
                const perPage = 2;
                let current = 0;
                let autoScrollTimer = null;
                let isTransitioning = false;

                const totalPages = Math.ceil(originalSlides.length / perPage);

                // 맨 처음 두 아이템을 목업으로 끝에 복사하여 붙여넣음 (오른쪽으로 계속 진행하는 듯한 이펙트)
                if (totalPages > 1 && track) {
                    for (let i = 0; i < perPage; i++) {
                        if (originalSlides[i]) {
                            const clone = originalSlides[i].cloneNode(true);
                            track.appendChild(clone);
                        }
                    }
                }

                function updateSlideWidths() {
                    const allSlides = track ? Array.from(track.querySelectorAll('.series-slide')) : [];
                    allSlides.forEach(slide => {
                        if (allSlides.length === 1) {
                            slide.style.width = '100%';
                        } else {
                            slide.style.width = 'calc(50% - 12px)';
                        }
                    });
                }

                function buildDots() {
                    if (!dotsContainer || totalPages <= 1) return;
                    for (let i = 0; i < totalPages; i++) {
                        const dot = document.createElement('button');
                        dot.className = 'w-2 h-2 rounded-full transition-all duration-300 ' + (i === 0 ? 'bg-[var(--primary)] w-5' : 'bg-black/20 dark:bg-white/20');
                        dot.addEventListener('click', () => { if(!isTransitioning) { goTo(i); startAutoScroll(); } });
                        dotsContainer.appendChild(dot);
                    }
                }

                function updateDots() {
                    if (!dotsContainer) return;
                    const activeIndex = current >= totalPages ? 0 : current;
                    Array.from(dotsContainer.children).forEach((dot, i) => {
                        dot.className = 'w-2 h-2 rounded-full transition-all duration-300 ' + (i === activeIndex ? 'bg-[var(--primary)]' : 'bg-black/20 dark:bg-white/20');
                        if (i === activeIndex) dot.style.width = '20px';
                        else dot.style.width = '';
                    });
                }

                function getPageWidth() {
                    if (!track || originalSlides.length === 0) return 0;
                    const carousel = document.getElementById('series-carousel');
                    return carousel ? carousel.offsetWidth + 24 : 0; // gap-6 = 24px
                }

                function updateTrackPosition(index, animate = true) {
                    const offset = index * getPageWidth();
                    if (animate) {
                        track.style.transition = 'transform 500ms ease-in-out';
                    } else {
                        track.style.transition = 'none';
                    }
                    track.style.transform = `translateX(-${offset}px)`;
                }

                function goTo(page) {
                    if (isTransitioning) return;

                    if (page >= totalPages) {
                        // 복제된 마지막 첫페이지 모방본으로 먼저 이동 (애니메이션 재생)
                        current = totalPages;
                        updateTrackPosition(current, true);
                        isTransitioning = true;
                        updateDots();

                        // 500ms(트랜지션 듀레이션) 대기 후 깜빡임 없이 실제 첫방으로 복귀
                        setTimeout(() => {
                            current = 0;
                            updateTrackPosition(current, false);
                            
                            // 강제로 Reflow 시켜서 변경사항 즉각 반영 (none transition이 적용되게 함)
                            void track.offsetWidth;
                            
                            isTransitioning = false;
                        }, 500);

                    } else if (page < 0) {
                        // 첫번째에서 왼쪽으로 되돌아갈 때: 애니메이션 끄고 끝으로 점프, 그후 부드럽게 뒤에서 앞으로 슬라이드
                        current = totalPages;
                        updateTrackPosition(current, false);
                        void track.offsetWidth;

                        current = totalPages - 1;
                        updateTrackPosition(current, true);
                        updateDots();
                    } else {
                        current = page;
                        updateTrackPosition(current, true);
                        updateDots();
                    }

                    if (prevBtn) prevBtn.style.display = totalPages > 1 ? 'flex' : 'none';
                    if (nextBtn) nextBtn.style.display = totalPages > 1 ? 'flex' : 'none';
                }

                function startAutoScroll() {
                    if (totalPages <= 1) return;
                    stopAutoScroll();
                    autoScrollTimer = setInterval(() => {
                        if(!isTransitioning) goTo(current + 1);
                    }, 4000);
                }

                function stopAutoScroll() {
                    if (autoScrollTimer) clearInterval(autoScrollTimer);
                }

                // Init
                updateSlideWidths();
                buildDots();

                if (totalPages > 1) {
                    if (nextBtn) nextBtn.style.display = 'flex';
                    if (prevBtn) prevBtn.style.display = 'flex';
                    if (prevBtn) prevBtn.addEventListener('click', () => { if(!isTransitioning) { goTo(current - 1); startAutoScroll(); } });
                    if (nextBtn) nextBtn.addEventListener('click', () => { if(!isTransitioning) { goTo(current + 1); startAutoScroll(); } });

                    const carouselWrapper = document.getElementById('series-carousel');
                    if (carouselWrapper) {
                        carouselWrapper.addEventListener('mouseenter', stopAutoScroll);
                        carouselWrapper.addEventListener('mouseleave', startAutoScroll);
                    }

                    startAutoScroll();
                }

                // Recalculate on resize
                window.addEventListener('resize', () => {
                   updateTrackPosition(current, false);
                });
            })();
        </script>
    </div>

    <!-- Paper of the Day Section -->
    <div class="max-w-[var(--page-width)] mx-auto px-4 pt-4 pb-8 mb-4">
        <div class="text-left mb-6 section-header opacity-0 translate-y-8 transition duration-700 ease-out">
            <h2 class="text-3xl font-bold text-black/75 dark:text-white/75 mb-2">📄 Paper of the Day</h2>
            <p class="text-black/50 dark:text-white/50">Staying updated with the latest research.</p>
        </div>
        <div class="daily-paper-widget opacity-0 translate-y-8 transition duration-700 ease-out">
            <DailyPaperWidget client:visible />
        </div>
    </div>

    <!-- Knowledge Graph Section -->
    <div class="max-w-[var(--page-width)] mx-auto px-4 pt-4 pb-8 mb-16">
        <div class="text-left mb-6 section-header opacity-0 translate-y-8 transition duration-700 ease-out">
            <h2 class="text-3xl font-bold text-black/75 dark:text-white/75 mb-2">🕸️ Knowledge Graph</h2>
            <p class="text-black/50 dark:text-white/50">Explore connections between posts.</p>
        </div>
        <div class="opacity-0 translate-y-8 transition duration-700 ease-out graph-view-container">
            <GraphView client:only="svelte" />
        </div>
    </div>

    <script>
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry, index) => {
                if (entry.isIntersecting) {
                    setTimeout(() => {
                        entry.target.classList.remove('opacity-0', 'translate-y-8');
                    }, index * 100); // Staggered delay
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.project-card, .skill-card, .section-header, .timeline-item, .recent-post-card, .daily-paper-widget, .graph-view-container').forEach((card) => {
            observer.observe(card);
        });
    </script>
</HomeLayout>
